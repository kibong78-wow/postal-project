{
  "rewrites": [
    { "source": "/api/ai",     "destination": "/api/ai.js" },
    { "source": "/api/image",  "destination": "/api/image.js" },
    { "source": "/api/update", "destination": "/api/update.js" },
    { "source": "/(.*)",       "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
